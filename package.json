{
  "name": "crew-predictions",
  "version": "1.0.0",
  "description": "This is another nearly decade old idea.  The idea of this project is to allow for public humiliation of the various Columbus Crew prediction challenges that #Crew96 podcasts offer",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:rules": "vitest run src/__tests__/firestore-rules.test.ts",
    "test": "bddgen && playwright test",
    "test:ui": "bddgen && playwright test --ui",
    "test:report": "playwright show-report",
    "test:gen": "bddgen",
    "test:smoke": "bddgen --config playwright.smoke.ts && playwright test --config playwright.smoke.ts",
    "test:smoke:debug": "SMOKE_DEBUG=1 bddgen --config playwright.smoke.ts && SMOKE_DEBUG=1 playwright test --config playwright.smoke.ts",
    "test:smoke:prod": "bddgen --config playwright.prod-smoke.ts && playwright test --config playwright.prod-smoke.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcornell/crew-predictions.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mcornell/crew-predictions/issues"
  },
  "homepage": "https://github.com/mcornell/crew-predictions#readme",
  "engines": {
    "node": "^24"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "10.3.0",
    "eslint-plugin-vue": "10.9.1",
    "firebase-tools": "15.17.0",
    "globals": "17.6.0",
    "jsdom": "^29.0.2",
    "playwright-bdd": "^8.5.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "8.59.2",
    "vite": "^8.0.8",
    "vite-plugin-webfont-dl": "^3.12.0",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "firebase": "^12.12.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  }
}
