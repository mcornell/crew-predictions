{
  "name": "crew-predictions",
  "version": "1.0.0",
  "description": "This is another nearly decade old idea.  The idea of this project is to allow for public humiliation of the various Columbus Crew prediction challenges that #Crew96 podcasts offer",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test": "bddgen && playwright test",
    "test:ui": "bddgen && playwright test --ui",
    "test:report": "playwright show-report",
    "test:gen": "bddgen"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcornell/crew-predictions.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mcornell/crew-predictions/issues"
  },
  "homepage": "https://github.com/mcornell/crew-predictions#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.0.2",
    "playwright-bdd": "^8.5.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "firebase": "^11.10.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  }
}
