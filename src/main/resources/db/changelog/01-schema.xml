<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">
    <changeSet id="1" author="mcornell">
        <createTable remarks="MLS Teams"
                     tableName="team">
            <column name="id" type="SMALLINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_team"/>
            </column>
            <column name="name" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <loadData catalogName="cat"
                  file="db/changelog/01-teams.csv"
                  quotchar="&quot;"
                  separator=","
                  tableName="team">
            <column name="name" type="STRING"/>
        </loadData>
        <createTable remarks="Games to Predict"
                     tableName="game">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_game"/>
            </column>
            <column name="home" type="SMALLINT">
                <constraints nullable="false" foreignKeyName="fk_home_team" references="team(id)"/>
            </column>
            <column name="away" type="SMALLINT">
                <constraints nullable="false" foreignKeyName="fk_away_team" references="team(id)"/>
            </column>
            <column name="homeGoals" type="SMALLINT" defaultValue="0">
                <constraints nullable="false" />
            </column>
            <column name="awayGoals" type="SMALLINT" defaultValue="0">
                <constraints nullable="false" />
            </column>
        </createTable>
        <loadData catalogName="cat"
                  file="db/changelog/01-games.csv"
                  quotchar="&quot;"
                  separator=","
                  tableName="game">
            <column name="home" type="NUMERIC"/>
            <column name="away" type="NUMERIC"/>
            <column name="homeGoals" type="NUMERIC"/>
            <column name="awayGoals" type="NUMERIC"/>
        </loadData>
        <createTable remarks="Shitlords"
                     tableName="handle">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_user"/>
            </column>
            <column name="handle" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="prediction">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_prediction"/>
            </column>
            <column name="game" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_game" references="game(id)"/>
            </column>
            <column name="handle" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_handle" references="handle(id)"/>
            </column>
            <column name="homeGoals" type="SMALLINT" defaultValue="0">
                <constraints nullable="false" />
            </column>
            <column name="awayGoals" type="SMALLINT" defaultValue="0">
                <constraints nullable="false" />
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>