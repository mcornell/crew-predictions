rules_version = '2';

// Crew Predictions Firestore security rules.
//
// This app has no client-side Firestore access. All reads and writes go
// through the Go service on Cloud Run via the Firebase Admin SDK, which
// bypasses these rules entirely. The frontend never imports the Firestore
// web SDK — its only contract with the backend is the /api/* and /auth/*
// HTTP endpoints. The project ID is publicly visible (served at
// /auth/config.js for Firebase Auth), so any rule that permits client
// access is an external surface anyone with the project ID can hit.
//
// Posture: deny-all. If a future change introduces a frontend Firestore
// SDK call, do not relax these rules — re-architect through an HTTP
// endpoint, or re-audit via /firestore-security-rules-auditor before
// permitting any client access. See internal/CLAUDE.md.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
