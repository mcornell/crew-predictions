package templates

import "github.com/mcornell/crew-predictions/internal/models"

templ MatchList(matches []models.Match) {
	@Layout("Crew Predictions") {
		<h1>Upcoming Matches</h1>
		for _, m := range matches {
			<div data-testid="match-card">
				{ m.HomeTeam } vs { m.AwayTeam }
			</div>
		}
	}
}
