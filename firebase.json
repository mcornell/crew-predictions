{
  "hosting": {
    "public": "dist",
    "versions": { "maxVersions": 5 },
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      },
      {
        "source": "**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": { "serviceId": "crew-predictions", "region": "us-east5" }
      },
      {
        "source": "/auth/**",
        "run": { "serviceId": "crew-predictions", "region": "us-east5" }
      },
      {
        "source": "/admin/**",
        "run": { "serviceId": "crew-predictions", "region": "us-east5" }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8081
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}
