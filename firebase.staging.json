{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      },
      {
        "source": "**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": { "serviceId": "crew-predictions-staging", "region": "us-east5" }
      },
      {
        "source": "/auth/**",
        "run": { "serviceId": "crew-predictions-staging", "region": "us-east5" }
      },
      {
        "source": "/admin/**",
        "run": { "serviceId": "crew-predictions-staging", "region": "us-east5" }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
